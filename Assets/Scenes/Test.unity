  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dieses Dark Pattern nutzt emotionale Assoziationen, um deine Wahrnehmung
    eines Produkts zu beeinflussen \u2013 und dich dadurch zu einer bestimmten Entscheidung
    zu bewegen. Es kombiniert Musik, Licht, oder Social-Media-Elemente, um gezielt
    positive oder negative Gef\xFChle auszul\xF6sen.\n\nIm erlebten Szenario wurden
    zwei Produkte gezielt unterschiedlich inszeniert: Das eine in d\xFCsterer Atmosph\xE4re
    mit kritischen Stimmen und negativen Kommentaren, das andere in freundlichem
    Licht, mit positiver Musik, Likes und Social-Media-Hinweisen. So sollte eines
    abgewertet und das andere attraktiver erscheinen \u2013 ganz ohne sachliche Gr\xFCnde.\n\nSolche
    Assoziationen sind nichts Neues \u2013 du kennst sie aus TV-Werbung oder Online-Shops.
    Aber AR verst\xE4rkt diese Wirkung: Anders als bei klassischen Medien wirkt das
    Produkt in deinem Raum glaubw\xFCrdig und direkt erfahrbar. Die Kombination aus
    visuellen Reizen, sozialem Druck und emotionaler Stimmung kann deine Wahrnehmung
    so stark beeinflussen, dass du glaubst, eine \u201Eeigene\u201C Entscheidung
    zu treffen \u2013 obwohl sie l\xE4ngst vorbereitet wurde."
  m_isRightToLeft: 0
