  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dieses Dark Pattern nutzt gezielt die r\xE4umliche Platzierung virtueller
    Inhalte, um wichtige Informationen oder Auswahlm\xF6glichkeiten zu verstecken
    \u2013 und dich so zu einer Entscheidung zu bewegen, die du m\xF6glicherweise
    sonst nicht treffen w\xFCrdest.\n\nIm gerade erlebten Szenario wurde ein Cookie-Banner
    an einer Stelle eingeblendet, an der es teilweise von einem realen Regal verdeckt
    war. Dadurch konntest du nicht alle Inhalte lesen, und besonders der \u201EAblehnen\u201C-Button
    war schwer zu erkennen oder zu erreichen. Die Gestaltung war kein Zufall: Sie
    sollte es dir bewusst erschweren, der Cookie-Nutzung zu widersprechen, da dies
    die weniger vorteilhafte Option f\xFCr das System w\xE4re.\n\nIm Unterschied
    zu klassischen Interfaces auf einem Bildschirm nutzt AR physische Objekte in
    deiner Umgebung als Teil der Manipulation. Verdeckungen entstehen hier nicht
    durch Pop-ups oder Scrollbar-M\xE4ngel \u2013 sondern durch reale Objekte in
    deiner Umgebung. So wirkt die Einschr\xE4nkung deiner Entscheidungsfreiheit subtiler
    und schwerer nachvollziehbar."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
