  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Dieses Dark Pattern nutzt gezielt platzierte Werbung in deiner Umgebung,
    um dich emotional zu beeinflussen und zum Kauf zu verleiten. Im Gegensatz zu
    klassischer Werbung auf einem Bildschirm wirken diese Inhalte realistisch und
    sind nahtlos in deinen Alltag eingebettet \u2013 etwa als dampfende Pizza auf
    deinem Tisch oder als virtuelle M\xF6bel im Raum.\n\nDie Werbung orientiert sich
    an deinem aktuellen Kontext:\nHast du gerade kein Essen auf deinem Esstisch,
    erscheint eine verlockende Mahlzeit. Blickst du aus dem Fenster, wird dein Wohnort
    grau und trist dargestellt \u2013 w\xE4hrend stattdessen eine sonnige Urlaubsszene
    auftaucht. Dabei werden gezielt Emotionen wie Unzufriedenheit, Hunger, Fernweh
    oder Unsicherheit angesprochen.\n\nDurch realistische Darstellungen und manipulativ-emotionale
    Sprache werden Bed\xFCrfnisse erzeugt, die dir vorher vielleicht gar nicht bewusst
    waren \u2013 und gleichzeitig scheinbare L\xF6sungen angeboten. Anders als klassische
    Fernsehwerbung erscheint diese Form der Werbung \xFCberall dort, wo sie dich
    am st\xE4rksten treffen kann: genau vor dir, neben dir, \xFCber deinem Bett,
    auf deinem Esstisch. Und genau das macht dieses Dark Pattern so gef\xE4hrlich."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
